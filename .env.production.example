# ============================================================
# Variables de entorno para el backend en Render (PRODUCCIÓN)
# Copia estas variables en: Render → tu servicio → Environment
# ============================================================

APP_NAME=KLYX
APP_ENV=production
APP_KEY=                        # Genera con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://TU-BACKEND.onrender.com

# ——— Base de datos (Supabase) ———
DB_CONNECTION=pgsql
DB_HOST=db.XXXXXXXXXX.supabase.co   # Settings → Database → Host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=TU_PASSWORD_SUPABASE

# ——— Sesión y caché (sin base de datos extra) ———
SESSION_DRIVER=cookie
CACHE_STORE=array
QUEUE_CONNECTION=sync

# ——— CORS: URL exacta de tu frontend en Render ———
FRONTEND_URL=https://TU-FRONTEND.onrender.com

# ——— Logs ———
LOG_CHANNEL=stderr
LOG_LEVEL=error
